---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Photography portfolio' } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">STUDIO<span>.</span></a>
      <nav>
        <a href="/">Gallery</a>
        <a href="/about/">About</a>
        <a href="/contact/">Contact</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} Studio. All rights reserved.</p>
    </footer>

    <!-- Lightbox overlay -->
    <div id="lightbox" class="lightbox" aria-hidden="true">
      <button class="lb-close" aria-label="Close">&times;</button>
      <img class="lb-img" src="" alt="" />
    </div>

    <script>
      const lb = document.getElementById('lightbox')!;
      const lbImg = lb.querySelector('.lb-img') as HTMLImageElement;
      document.querySelectorAll('[data-lightbox]').forEach((el) => {
        el.addEventListener('click', (e) => {
          e.preventDefault();
          const src = (el as HTMLElement).dataset.src || '';
          const alt = (el as HTMLElement).dataset.alt || '';
          lbImg.src = src;
          lbImg.alt = alt;
          lb.classList.add('open');
          lb.setAttribute('aria-hidden', 'false');
        });
      });
      const close = () => {
        lb.classList.remove('open');
        lb.setAttribute('aria-hidden', 'true');
        lbImg.src = '';
      };
      lb.querySelector('.lb-close')!.addEventListener('click', close);
      lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0d0d0f;
    --surface: #161618;
    --fg: #f4f1ea;
    --muted: #8c8c90;
    --accent: #d8a657;
    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans: 'Inter', system-ui, sans-serif;
  }
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  html, body { margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--fg);
    font-family: var(--sans);
    font-weight: 300;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }
  a { color: inherit; text-decoration: none; }
  h1, h2, h3 { font-family: var(--serif); font-weight: 500; letter-spacing: 0.01em; }
  .site-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.4rem 2rem; border-bottom: 1px solid #1e1e21;
    position: sticky; top: 0; background: rgba(13,13,15,0.85); backdrop-filter: blur(8px); z-index: 50;
  }
  .brand { font-family: var(--serif); font-size: 1.5rem; letter-spacing: 0.12em; }
  .brand span { color: var(--accent); }
  nav a { margin-left: 1.8rem; color: var(--muted); font-size: 0.85rem; letter-spacing: 0.08em; text-transform: uppercase; transition: color 0.2s; }
  nav a:hover { color: var(--fg); }
  main { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
  .site-footer { text-align: center; color: var(--muted); padding: 3rem 2rem; border-top: 1px solid #1e1e21; font-size: 0.85rem; margin-top: 4rem; }

  /* Lightbox */
  .lightbox {
    position: fixed; inset: 0; background: rgba(8,8,10,0.94);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.25s; z-index: 100;
  }
  .lightbox.open { opacity: 1; pointer-events: auto; }
  .lightbox .lb-img { max-width: 92vw; max-height: 92vh; border-radius: 4px; box-shadow: 0 20px 60px rgba(0,0,0,0.6); }
  .lightbox .lb-close {
    position: absolute; top: 1.2rem; right: 1.6rem; background: none; border: none;
    color: var(--fg); font-size: 2.4rem; line-height: 1; cursor: pointer; opacity: 0.7;
  }
  .lightbox .lb-close:hover { opacity: 1; }

  @media (max-width: 600px) {
    .site-header { padding: 1rem 1.2rem; }
    nav a { margin-left: 1rem; font-size: 0.75rem; }
    main { padding: 0 1.2rem; }
  }
</style>
