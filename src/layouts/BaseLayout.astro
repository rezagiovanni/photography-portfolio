---
interface Props {
  title: string;
  description?: string;
  transparentNav?: boolean;
}
const { title, description = 'Photography portfolio', transparentNav = false } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header id="site-header" class={`site-header${transparentNav ? ' transparent' : ''}`}>
      <a class="brand" href="/">STUDIO<span>.</span></a>
      <nav>
        <a href="/">Gallery</a>
        <a href="/about/">About</a>
        <a href="/contact/">Contact</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="foot-cols">
        <div>
          <p class="foot-brand">STUDIO<span>.</span></p>
          <p class="foot-tag">Fine art &amp; portrait photography.</p>
        </div>
        <div>
          <p class="foot-head">Explore</p>
          <a href="/">Gallery</a>
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
        </div>
        <div>
          <p class="foot-head">Connect</p>
          <a href="#">Instagram</a>
          <a href="#">Behance</a>
          <a href="/contact/">Email</a>
        </div>
      </div>
      <p class="foot-copy">&copy; {new Date().getFullYear()} Studio. All rights reserved.</p>
    </footer>

    <!-- Lightbox overlay -->
    <div id="lightbox" class="lightbox" aria-hidden="true">
      <button class="lb-close" aria-label="Close">&times;</button>
      <img class="lb-img" src="" alt="" />
    </div>

    <script>
      // Transparent navbar -> solid on scroll (only when .transparent is set, i.e. home)
      const header = document.getElementById('site-header')!;
      if (header.classList.contains('transparent')) {
        const onScroll = () => {
          if (window.scrollY > 60) header.classList.add('scrolled');
          else header.classList.remove('scrolled');
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }

      const lb = document.getElementById('lightbox')!;
      const lbImg = lb.querySelector('.lb-img') as HTMLImageElement;
      document.querySelectorAll('[data-lightbox]').forEach((el) => {
        el.addEventListener('click', (e) => {
          e.preventDefault();
          const src = (el as HTMLElement).dataset.src || '';
          const alt = (el as HTMLElement).dataset.alt || '';
          lbImg.src = src;
          lbImg.alt = alt;
          lb.classList.add('open');
          lb.setAttribute('aria-hidden', 'false');
        });
      });
      const close = () => {
        lb.classList.remove('open');
        lb.setAttribute('aria-hidden', 'true');
        lbImg.src = '';
      };
      lb.querySelector('.lb-close')!.addEventListener('click', close);
      lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f7f5f0;
    --surface: #ffffff;
    --fg: #1a1a1a;
    --muted: #6b6b6b;
    --line: #e2ded5;
    --accent: #8a6d3b;
    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans: 'Inter', system-ui, sans-serif;
  }
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  html, body { margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--fg);
    font-family: var(--sans);
    font-weight: 300;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }
  a { color: inherit; text-decoration: none; }
  h1, h2, h3 { font-family: var(--serif); font-weight: 500; letter-spacing: 0.01em; }
  .site-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.6rem 2.5rem; border-bottom: 1px solid var(--line);
    position: fixed; top: 0; left: 0; right: 0; background: rgba(247,245,240,0.9); backdrop-filter: blur(8px); z-index: 50;
    transition: background 0.35s ease, border-color 0.35s ease, padding 0.35s ease;
  }
  /* Home: hero is full-bleed behind the transparent navbar (no top padding) */
  main { padding-top: 0; }
  /* Other pages: push content below the fixed navbar */
  .site-header:not(.transparent) + main { padding-top: 5.5rem; padding-left: 2.5rem; padding-right: 2.5rem; }
  .site-header.transparent {
    background: transparent; backdrop-filter: none; border-bottom-color: transparent; padding: 2rem 2.5rem;
  }
  .site-header.transparent .brand,
  .site-header.transparent nav a { color: #f7f5f0; text-shadow: 0 1px 12px rgba(0,0,0,0.4); }
  .site-header.transparent.scrolled {
    background: rgba(247,245,240,0.92); backdrop-filter: blur(10px); border-bottom-color: var(--line); padding: 1.4rem 2.5rem;
  }
  .site-header.transparent.scrolled .brand,
  .site-header.transparent.scrolled nav a { color: var(--muted); text-shadow: none; }
  .site-header.transparent.scrolled nav a:hover { color: var(--fg); }
  .site-header.scrolled { border-bottom-color: var(--line); }
  .brand { font-family: var(--serif); font-size: 1.6rem; letter-spacing: 0.12em; }
  .brand span { color: var(--accent); }
  nav a { position: relative; margin-left: 2rem; color: var(--muted); font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; transition: color 0.25s; }
  nav a::after { content: ''; position: absolute; left: 0; right: 0; bottom: -6px; height: 1.5px; background: currentColor; transform: scaleX(0); transform-origin: center; transition: transform 0.3s ease; }
  nav a:hover { color: var(--fg); }
  nav a:hover::after { transform: scaleX(1); }
  main { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; }
  .site-footer { background: #efece4; margin-top: 6rem; padding: 4rem 2.5rem 2rem; border-top: 1px solid var(--line); }
  .foot-cols { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 2rem; max-width: 1200px; margin: 0 auto; }
  .foot-brand { font-family: var(--serif); font-size: 1.5rem; letter-spacing: 0.12em; margin: 0 0 0.4rem; }
  .foot-brand span, .foot-copy span { color: var(--accent); }
  .foot-tag { color: #555; font-size: 0.9rem; margin: 0; }
  .foot-head { font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--fg); margin: 0 0 0.8rem; font-weight: 500; }
  .foot-cols a { display: block; color: #555; font-size: 0.9rem; margin-bottom: 0.5rem; }
  .foot-cols a:hover { color: var(--fg); }
  .foot-copy { text-align: center; color: var(--muted); font-size: 0.8rem; margin: 3rem 0 0; padding-top: 1.5rem; border-top: 1px solid var(--line); }

  /* Lightbox */
  .lightbox {
    position: fixed; inset: 0; background: rgba(20,18,16,0.95);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.25s; z-index: 100;
  }
  .lightbox.open { opacity: 1; pointer-events: auto; }
  .lightbox .lb-img { max-width: 92vw; max-height: 92vh; border-radius: 2px; box-shadow: 0 20px 60px rgba(0,0,0,0.6); }
  .lightbox .lb-close {
    position: absolute; top: 1.2rem; right: 1.6rem; background: none; border: none;
    color: #fff; font-size: 2.4rem; line-height: 1; cursor: pointer; opacity: 0.7;
  }
  .lightbox .lb-close:hover { opacity: 1; }

  @media (max-width: 600px) {
    .site-header { padding: 1.1rem 1.4rem; }
    nav a { margin-left: 1.1rem; font-size: 0.72rem; }
    main { padding: 0 1.4rem; }
    .foot-cols { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>
