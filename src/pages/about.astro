---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Studio">
  <section class="about">
    <div class="portrait">
      <img src="https://portofolio.rezagiovanni.my.id/original/04.jpg" alt="Photographer portrait" width="800" height="1100" loading="lazy" />
    </div>
    <div class="bio">
      <p class="eyebrow">About</p>
      <h1>The person behind the lens</h1>
      <p>
        [Bio placeholder] — Seorang fotografer yang suka menangkap cahaya dan
        momen tenang di antara kesibukan. Spesialisasi dalam portrait, landscape,
        dan street photography.
      </p>
      <p>
        [Placeholder] Pendekatan visual yang minimalis namun emosional —
        setiap frame punya cerita.
      </p>
      <a class="cta" href="/contact/">Get in touch →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .about { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 4rem; align-items: center; padding: 6rem 0; }
  .portrait img { width: 100%; height: auto; border-radius: 2px; display: block; box-shadow: 0 10px 40px rgba(0,0,0,0.08); }
  .eyebrow { color: var(--accent); letter-spacing: 0.25em; text-transform: uppercase; font-size: 0.78rem; margin: 0 0 0.8rem; }
  .bio h1 { font-size: clamp(2.2rem, 4vw, 3.2rem); margin: 0 0 1.6rem; }
  .bio p { color: var(--muted); margin: 0 0 1.3rem; max-width: 50ch; }
  .cta { display: inline-block; border: 1px solid var(--accent); color: var(--accent); padding: 0.75rem 1.8rem; border-radius: 999px; font-size: 0.88rem; transition: all 0.2s; }
  .cta:hover { background: var(--accent); color: #fff; }
  @media (max-width: 760px) { .about { grid-template-columns: 1fr; gap: 2.5rem; padding: 4rem 0; } }
</style>
