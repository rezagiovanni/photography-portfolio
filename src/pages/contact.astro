---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Photography Portfolio">
  <h1>Contact</h1>
  <p>Hubungi via form di bawah. (Formspree akan dihookup di Phase 7.)</p>
  <form class="contact-form" action="https://formspree.io/f/REPLACE_ME" method="POST">
    <label>Name<input type="text" name="name" required /></label>
    <label>Email<input type="email" name="email" required /></label>
    <label>Message<textarea name="message" rows="5" required></textarea></label>
    <button type="submit">Send</button>
  </form>
</BaseLayout>

<style>
  .contact-form { display: flex; flex-direction: column; gap: 1rem; max-width: 480px; }
  label { display: flex; flex-direction: column; gap: 0.3rem; color: var(--muted); }
  input, textarea {
    background: #161617; border: 1px solid #2a2a2c; color: var(--fg);
    padding: 0.6rem; border-radius: 6px; font: inherit;
  }
  button {
    align-self: flex-start; background: var(--accent); color: #000;
    border: none; padding: 0.6rem 1.4rem; border-radius: 6px; cursor: pointer; font-weight: 600;
  }
</style>
