---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Studio">
  <section class="contact">
    <p class="eyebrow">Contact</p>
    <h1>Let's create something.</h1>
    <p class="lead">Punya ide, booking sesi, atau sekadar menyapa — tulis aja di bawah.</p>
    <form class="contact-form" action="https://formspree.io/f/REPLACE_ME" method="POST">
      <label>Name<input type="text" name="name" required /></label>
      <label>Email<input type="email" name="email" required /></label>
      <label>Message<textarea name="message" rows="5" required></textarea></label>
      <button type="submit">Send message</button>
    </form>
  </section>
</BaseLayout>

<style>
  .contact { max-width: 560px; margin: 0 auto; padding: 5rem 0; text-align: center; }
  .eyebrow { color: var(--accent); letter-spacing: 0.25em; text-transform: uppercase; font-size: 0.78rem; margin: 0 0 0.8rem; }
  .contact h1 { font-size: clamp(2rem, 5vw, 3rem); margin: 0 0 1rem; }
  .lead { color: var(--muted); margin: 0 0 2.5rem; }
  .contact-form { display: flex; flex-direction: column; gap: 1.2rem; text-align: left; }
  label { display: flex; flex-direction: column; gap: 0.4rem; color: var(--muted); font-size: 0.85rem; letter-spacing: 0.05em; }
  input, textarea {
    background: var(--surface); border: 1px solid #2a2a2c; color: var(--fg);
    padding: 0.75rem; border-radius: 6px; font: inherit; font-weight: 300;
  }
  input:focus, textarea:focus { outline: none; border-color: var(--accent); }
  button {
    align-self: flex-start; background: var(--accent); color: #000; border: none;
    padding: 0.75rem 1.8rem; border-radius: 999px; cursor: pointer; font-weight: 500; letter-spacing: 0.03em;
    transition: opacity 0.2s;
  }
  button:hover { opacity: 0.88; }
</style>
