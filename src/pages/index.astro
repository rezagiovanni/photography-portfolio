---
import BaseLayout from '../layouts/BaseLayout.astro';

// Placeholder gallery. Real photos wired to GCS/CDN in Phase 3.
const photos = [
  { file: '01', title: 'Golden Hour', w: 800, h: 1200 },
  { file: '02', title: 'City Lines', w: 1200, h: 800 },
  { file: '03', title: 'Still Life', w: 1000, h: 1000 },
  { file: '04', title: 'Portrait', w: 800, h: 1100 },
  { file: '05', title: 'Horizon', w: 1200, h: 900 },
  { file: '06', title: 'Quiet', w: 900, h: 1200 },
  { file: '07', title: 'Motion', w: 1100, h: 800 },
  { file: '08', title: 'Form', w: 1000, h: 1000 },
  { file: '09', title: 'Shadow', w: 800, h: 1000 },
];
---

<BaseLayout title="Studio — Photography Portfolio">
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-inner">
      <p class="eyebrow">Photography Portfolio</p>
      <h1>Capturing light,<br />one frame at a time.</h1>
      <p class="sub">Portraits, landscapes &amp; the quiet moments in between.</p>
      <a class="cta" href="/contact/">Work with me →</a>
    </div>
  </section>

  <section class="gallery">
    {photos.map((p) => (
      <a
        class="tile"
        href={`/placeholder/${p.file}.jpg`}
        data-lightbox
        data-src={`/placeholder/${p.file}.jpg`}
        data-alt={p.title}
      >
        <img src={`/placeholder/${p.file}.jpg`} alt={p.title} width={p.w} height={p.h} loading="lazy" />
        <span class="caption">{p.title}</span>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    margin: 0 -2rem;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/placeholder/hero.jpg');
    background-size: cover;
    background-position: center;
    filter: grayscale(25%) brightness(0.55);
    transform: scale(1.05);
  }
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(13,13,15,0.35), rgba(13,13,15,0.85));
  }
  .hero-inner { position: relative; z-index: 1; padding: 2rem; }
  .eyebrow { color: var(--accent); letter-spacing: 0.25em; text-transform: uppercase; font-size: 0.78rem; margin: 0 0 1rem; }
  .hero h1 { font-size: clamp(2.4rem, 6vw, 4.6rem); line-height: 1.05; margin: 0 auto; max-width: 16ch; text-shadow: 0 2px 30px rgba(0,0,0,0.5); }
  .hero .sub { color: #d8d4cc; margin: 1.4rem auto 2rem; max-width: 42ch; }
  .cta { display: inline-block; border: 1px solid var(--accent); color: var(--accent); padding: 0.7rem 1.6rem; border-radius: 999px; font-size: 0.9rem; letter-spacing: 0.05em; transition: all 0.2s; background: rgba(0,0,0,0.25); }
  .cta:hover { background: var(--accent); color: #000; }

  .gallery {
    columns: 3; column-gap: 1rem; padding: 2rem 0 1rem;
  }
  .tile { display: block; position: relative; margin: 0 0 1rem; break-inside: avoid; overflow: hidden; border-radius: 6px; }
  .tile img { width: 100%; height: auto; display: block; transition: transform 0.4s ease, filter 0.4s; filter: grayscale(15%); }
  .tile:hover img { transform: scale(1.04); filter: grayscale(0); }
  .tile .caption {
    position: absolute; left: 0; bottom: 0; width: 100%; padding: 1.4rem 1rem 0.8rem;
    font-family: var(--serif); font-size: 1.05rem; color: #fff;
    background: linear-gradient(transparent, rgba(0,0,0,0.7)); opacity: 0; transition: opacity 0.3s;
  }
  .tile:hover .caption { opacity: 1; }

  @media (max-width: 900px) { .gallery { columns: 2; } }
  @media (max-width: 560px) { .gallery { columns: 1; } .hero { min-height: 70vh; margin: 0 -1.2rem; } }
</style>
